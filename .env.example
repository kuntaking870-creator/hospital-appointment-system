# Database Configuration
DATABASE_CONNECTION_STRING=Server=localhost;Database=HospitalAppointmentDB;User Id=sa;Password=YourPassword123;

# HMS Integration
HMS_API_BASE_URL=https://hms.hospital.local/api
HMS_API_KEY=your_api_key_here
HMS_SYNC_INTERVAL_SECONDS=300
HMS_CONNECTION_STRING=Server=hms-server;Database=HMS_DB;User Id=sa;Password=hms_password;

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_EXPIRATION_MINUTES=480
JWT_ISSUER=HospitalAppointmentSystem
JWT_AUDIENCE=HospitalAppointmentAPI

# LDAP/Active Directory
LDAP_ENABLED=true
LDAP_SERVER=ldap.hospital.local
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=dc=hospital,dc=local
LDAP_BIND_DN=CN=ServiceAccount,CN=Users,DC=hospital,DC=local
LDAP_BIND_PASSWORD=service_account_password

# Logging
LOG_LEVEL=Information
LOG_PATH=./logs
ELK_ENABLED=false
ELK_HOST=localhost
ELK_PORT=9200

# Application Settings
APP_NAME=Hospital Appointment System
APP_VERSION=1.0.0
APP_ENVIRONMENT=Development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email Configuration (for notifications)
SMTP_HOST=smtp.hospital.local
SMTP_PORT=587
SMTP_USERNAME=notifications@hospital.local
SMTP_PASSWORD=email_password
SMTP_FROM_ADDRESS=appointments@hospital.local
SMTP_FROM_NAME=Hospital Appointments

# Frontend Configuration
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_API_TIMEOUT=30000
REACT_APP_REFRESH_INTERVAL=30000
